[default]
agent = opencode
language = zh-CN

[profile.fast]
agent = opencode
agent_arg = --model=gpt-5.1
layout = down

[profile.merge]
agent = opencode
agent_arg = --model=gpt-5.1
layout = right
merge = true

# Team mode defaults. `agent` in [default]/[profile.*] is only a fallback for
# the leader; explicit team settings below take precedence.
[team.engineering]
leader_agent = opencode
worker_agent = pi

# Used only for roles that do not have a fixed agent below. The dispatcher
# filters this list to installed commands and randomly picks one.
worker_agent_pool = claude,codex

# Role-specific agents keep critical duties predictable while still allowing
# implementation/testing roles to use the pool.
workers = reviewer:claude,docs:claude,shipper:codex
max_active_workers = 1

# Optional: override the built-in role list. Leave unset to use the default
# engineering roles: investigator, architect, implementer, reviewer, tester, docs, shipper.
# roles = investigator,architect,implementer,reviewer,tester,docs,shipper
# disabled_roles = docs

[team.engineering.role.investigator]
name = Investigator
description = Investigate unclear problems, reproduce failures, trace root causes, and recommend the next role before implementation.
success = root cause, evidence, blockers, and recommended next role are reported clearly

[team.engineering.role.architect]
name = Architect
description = Design technical approach, module boundaries, data flow, APIs, and migration strategy before broad or risky changes.
success = technical design is scoped, testable, and explicit about tradeoffs and risks

[team.engineering.role.implementer]
name = Implementer
description = Implement scoped code changes in the shared worktree.
success = changes are minimal, verified, and summarized for the leader

[team.engineering.role.reviewer]
name = Code Reviewer
description = Review the current diff for correctness, security, maintainability, and missing tests.
success = findings are severity-ranked with file and line evidence

[team.engineering.role.tester]
name = Tester
description = Run focused verification and diagnose failures in the shared worktree.
success = test results and failure causes are reported clearly

[team.engineering.role.docs]
name = Documentation Writer
description = Update user-facing or maintainer documentation for the completed work.
success = documentation matches the shipped behavior

[team.engineering.role.shipper]
name = Shipper
description = Own final verification, commit project changes, and run the dispatcher merge command.
success = owned changes are committed and integrated, or a clear no-commit reason is reported
